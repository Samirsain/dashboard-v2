# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed origins, or "*" for any.
CORS_ORIGIN=*
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# JWT auth
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# ---------------------------------------------------------------------------
# Supabase — PRIMARY database (source of truth)
#
# Get these from the Supabase dashboard: Project Settings -> API.
# SUPABASE_SERVICE_ROLE_KEY is the service_role (secret) key — server-side
# ONLY, it bypasses Row Level Security. Never expose it to the browser.
# SUPABASE_SECRET_KEY is accepted as a fallback name for the same secret.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Backup trigger secret — lets an external scheduler (free GitHub Actions cron,
# cron-job.org, ...) call POST /api/backup/run to force a Supabase -> Sheets
# backup even when the host's in-process cron can't run (free tier sleeping).
# If unset, that endpoint is disabled. Use a long random string.
# ---------------------------------------------------------------------------
BACKUP_TOKEN=

# ---------------------------------------------------------------------------
# Google Sheets — now used only for the daily BACKUP of Supabase data.
# The app runs fine without these; the Sheets backup is just skipped.
# Provide ONE of the three credential options below.
# ---------------------------------------------------------------------------

# Option A (recommended for local dev): path to a service account key file
# on disk. Put the real key at backend/credentials/service-account.json —
# that folder is .gitignored so it never gets committed.
GOOGLE_SERVICE_ACCOUNT_PATH=./credentials/service-account.json

# Option B: paste the full service account JSON key as one line (handy for
# platforms where you can only set env vars, e.g. most PaaS deploys).
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Option C: split email + private key. Keep the \n escape sequences in the key.
# GOOGLE_SERVICE_ACCOUNT_EMAIL=my-service-account@my-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQ...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# Google Sheets — spreadsheet + tab names
#
# GOOGLE_SPREADSHEET_ID is the ID from your spreadsheet's URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_IS_THE_ID/edit
# Share that spreadsheet with the service account's client_email as Editor.
#
# Each entity below can override both the spreadsheet ID and the tab name
# independently, in case you split data across multiple spreadsheets. Leave
# the SHEET_*_NAME vars unset to use the defaults already wired into the app
# (DOERLIST, TASKLIST, Revisions, CHECKLIST, CHECKLIST_INSTANCES,
# ACTIVITY_LOGS). Missing tabs — and their header rows — are created
# automatically on first use.
# ---------------------------------------------------------------------------
GOOGLE_SPREADSHEET_ID=

# SHEET_USERS_SPREADSHEET_ID=
# SHEET_USERS_NAME=DOERLIST

# SHEET_TASKS_SPREADSHEET_ID=
# SHEET_TASKS_NAME=TASKLIST

# SHEET_REVISIONS_SPREADSHEET_ID=
# SHEET_REVISIONS_NAME=Revisions

# SHEET_CHECKLIST_TEMPLATES_SPREADSHEET_ID=
# SHEET_CHECKLIST_TEMPLATES_NAME=CHECKLIST

# SHEET_CHECKLIST_INSTANCES_SPREADSHEET_ID=
# SHEET_CHECKLIST_INSTANCES_NAME=CHECKLIST_INSTANCES

# SHEET_ACTIVITY_LOGS_SPREADSHEET_ID=
# SHEET_ACTIVITY_LOGS_NAME=ACTIVITY_LOGS

# ---------------------------------------------------------------------------
# Scheduler
# ---------------------------------------------------------------------------
SCHEDULER_ENABLED=true
# Standard 5-field cron expression. Default: 00:01 every day.
SCHEDULER_DAILY_CRON=1 0 * * *
# Supabase -> Google Sheets backup. Default: every 6 hours.
SCHEDULER_BACKUP_CRON=0 */6 * * *
SCHEDULER_TIMEZONE=Asia/Kolkata
